#!/bin/sh
#
# Pre-commit hook to run shellcheck and ruff
# Install: apk add shellcheck ruff --repository=http://dl-cdn.alpinelinux.org/alpine/edge/community

set -e

# Shellcheck
if command -v shellcheck >/dev/null 2>&1; then
    find . -type f -name "*.sh" ! -path "*/.git/*" -exec shellcheck {} +
fi

# Ruff
if command -v ruff >/dev/null 2>&1; then
    ruff check .
fi
