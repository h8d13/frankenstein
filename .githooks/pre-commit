#!/bin/sh
#
# Pre-commit hook to run shellcheck on all .sh files
# To install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: git config core.hooksPath .githooks

echo "Running shellcheck on shell scripts..."

# Find all .sh files and run shellcheck
find . -type f -name "*.sh" ! -path "*/.git/*" -print0 | while IFS= read -r -d '' file; do
    if ! shellcheck "$file"; then
        echo "Shellcheck failed for: $file"
        exit 1
    fi
done

echo "Shellcheck passed!"
exit 0
