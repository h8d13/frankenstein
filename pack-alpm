#!/bin/sh
# pack-alpm: Safely create a compressed copy of ALPM-FS
#   - Preserves directory structure
#   - Copies non-.sh files as-is
#   - Runs gscript on .sh files
# Usage: ./pack-alpm [source_dir] [output_dir]

set -e

SRC="${1:-ALPM-FS}"
OUT="${2:-ALPM-FS-packed}"
SCRIPT_DIR=$(dirname "$0")

if [ ! -d "$SRC" ]; then
    echo "Error: source directory '$SRC' not found" >&2
    exit 1
fi

if [ -d "$OUT" ]; then
    echo "Error: output directory '$OUT' already exists, remove it first" >&2
    exit 1
fi

if [ ! -f "$SCRIPT_DIR/gscript" ] || [ ! -f "$SCRIPT_DIR/minish" ]; then
    echo "Error: gscript and minish must be in $SCRIPT_DIR" >&2
    exit 1
fi

# Skip runtime dirs (chroot environments, build artifacts)
SKIP="alpinestein"

# Record before size (exclude skipped dirs)
before=$(du -sb --exclude="$SKIP" --exclude=".git" "$SRC" | cut -f1)

# Recreate directory structure
find "$SRC" -type d -not -path '*/.git/*' -not -path '*/.git' -not -path "*/$SKIP/*" -not -path "*/$SKIP" | while read -r dir; do
    mkdir -p "$OUT${dir#"$SRC"}"
done

# Process files
find "$SRC" -type f -not -path '*/.git/*' -not -path "*/$SKIP/*" | while read -r file; do
    rel="${file#"$SRC"}"
    case "$file" in
        */assets/*.sh|*/assets/**/*.sh)
            # Assets are sourced/copied into chroot — don't gscript
            cp "$file" "$OUT$rel"
            echo "[copy]    $rel"
            ;;
        *.sh)
            cp "$file" "$OUT$rel"
            "$SCRIPT_DIR/gscript" "$OUT$rel"
            mv "$OUT${rel}.gz" "$OUT$rel"
            echo "[gscript] $rel"
            ;;
        *)
            cp "$file" "$OUT$rel"
            echo "[copy]    $rel"
            ;;
    esac
done

# Record after size
after=$(du -sb "$OUT" | cut -f1)
saved=$((before - after))
if [ "$before" -gt 0 ]; then
    pct=$((saved * 100 / before))
else
    pct=0
fi

echo ""
echo "=== Summary ==="
echo "Source:  $SRC  ($before bytes)"
echo "Output:  $OUT  ($after bytes)"
echo "Saved:   $saved bytes ($pct%)"
